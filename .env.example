# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# Comma-separated list of device management IPs
DEVICE_IPS=192.168.1.1,192.168.1.2,10.0.0.1

# SSH credentials
SSH_USERNAME=your_username
SSH_PASSWORD=your_password

# SSH port (default: 22)
SSH_PORT=22

# Optional: seconds to wait after each command (default: 2.5)
# Increase for slower/older devices
CMD_DELAY=2.5
